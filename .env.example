# ============================================================
# Solana Multi-Agent Trading Loop - Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# --- Solana Network ---
# Mainnet: https://api.mainnet-beta.solana.com
# Devnet:  https://api.devnet.solana.com
RPC_URL=https://api.mainnet-beta.solana.com

# Your Solana wallet private key (base58 encoded)
# WARNING: Keep this secret. Never share or commit.
SOLANA_PRIVATE_KEY=your_base58_private_key_here

# --- GMGN API ---
# Obtain from https://gmgn.ai/
GMGN_API_KEY=your_gmgn_api_key_here
GMGN_API_BASE_URL=https://api.gmgn.ai/v1

# --- Gemini (Google AI) ---
# Obtain from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# --- DeepSeek ---
# Obtain from https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- Grok (xAI) ---
# Obtain from https://console.x.ai/
GROK_API_KEY=your_grok_api_key_here
GROK_API_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-2-latest

# --- Jupiter Aggregator ---
JUPITER_API_BASE_URL=https://quote-api.jup.ag/v6

# --- Trading Parameters ---
# Minimum score from Gemini to pass to DeepSeek (1-10)
GEMINI_SCORE_THRESHOLD=7
# Minimum conviction score from DeepSeek to execute trade (1-10)
DEEPSEEK_CONVICTION_THRESHOLD=8
# Amount in lamports to swap per trade (1 SOL = 1000000000)
TRADE_AMOUNT_LAMPORTS=10000000
# SOL mint address (wrapped SOL)
SOL_MINT=So11111111111111111111111111111111111111112
# Loop polling interval in milliseconds
POLL_INTERVAL_MS=30000
# Rate limit retry delay in milliseconds
RATE_LIMIT_RETRY_MS=10000
